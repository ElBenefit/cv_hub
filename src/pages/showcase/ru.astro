import { getEntry } from 'astro:content';
import Layout from '../../components/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const lang = 'ru';

// projects.yaml лежит в коллекции showcase, entry id = 'projects'
const entry = await getEntry('showcase', 'projects');
const projects = entry?.data?.projects ?? [];
---

<Layout title="Проекты" lang={lang} section="showcase">
  <section class="container">
    <h1>Шоукейс</h1>

    <div class="grid">
      {projects.map((p) => (
        <ProjectCard project={p} lang={lang} />
      ))}
    </div>
  </section>
</Layout>

